Table GT_DIC_TAREFAS {
  ID int [pk, increment]
  DESCRICAO_PT varchar(255)
  DESCRICAO_ENG varchar(255)
  DESCRICAO_FR varchar(255)
  DATA_CRIA datetime
  UTZ_CRIA int
  DATA_ULT_MODIF datetime
  UTZ_ULT_MODIF int
  TIPO_TAREFA varchar(255)

}

Table GT_DIC_TIPO_ACAO {
  ID_TIPO_ACAO int [pk, increment]
  DESCRICAO varchar(255)
  DATA_CRIA datetime
  UTZ_CRIA int
  DATA_MODIF datetime
  UTZ_MODIF int

}

Table GT_LOGS {
  ID int [pk, increment]
  DATA_CRIA datetime
  UTZ_CRIA int
  DESCRICAO varchar(255)
  ID_TAREFA int
  JUSTIFICACAO varchar(255)

}

Table GT_MOV_FICHEIROS {
  ID int
  TAMANHO float
  NOME varchar(255)

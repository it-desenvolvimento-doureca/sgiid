// Module: CO
// SGIID Database - Generated from JPA entities + DAO queries
// SQL Server | DataSource: java:jboss/datasources/SGIID

Table CO_ANALISE_CLIENTES {
  ID int
  CLICOD varchar(255)
  ETSNUM varchar(255)
  PROREF varchar(255)
  ID_LINHA int
  STOCK_CLIENTE decimal(18,4)
  DATA_STOCK_CLIENTE date
  UTZ_CRIA int
  DATA_CRIA datetime
  UTZ_MODIF int
  DATA_MODIF datetime

}


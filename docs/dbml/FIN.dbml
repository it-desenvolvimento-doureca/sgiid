// Module: FIN
// SGIID Database - Generated from JPA entities + DAO queries
// SQL Server | DataSource: java:jboss/datasources/SGIID

Table FIN_DIC_CLIENTES {
  ID int
  ID_CLIENTE varchar(255)
  FUNCAO_1 varchar(255)
  NOME_1 varchar(255)
  EMAIL_1 varchar(255)
  TLM_1 varchar(255)
  FUNCAO_2 varchar(255)
  NOME_2 varchar(255)
  EMAIL_2 varchar(255)
  TLM_2 varchar(255)
  UTZ_MODIF int
  DATA_MODIF datetime
  BLOQUEADO bit

}

Table FIN_DIC_FILTROS {
  ID int
  TIPO_ANALISE int
  DESCRICAO varchar(255)
  PROTYPCOD varchar(255)
  ACHFAMCOD varchar(255)

}

Table FIN_DIC_OBJETIVOS {
  ID_OBJETIVO int
  MES int
  ANO int
  VALOR_OBJETIVO float
  N_DIAS_UTEIS int
  VALOR_OBJETIVO_ANUAL float
  VALOR_OBJETIVO_TOOLS float

}

Table FIN_DIC_PARAMETROS_SEGUIMENTO {
  ID_ANALISE int
  DESCRICAO varchar(255)
  TIPOS_DOCUMENTO varchar(255)
  TIPO_ARTIGO varchar(255)

}

Table FIN_DIC_TIPO_DOC {
  ID int
  TIPO_DOCUMENTO varchar(255)
  NOME_DOCUMENTO varchar(255)
  TIPO_FICHEIRO_1 varchar(255)
  TIPO_FICHEIRO_2 varchar(255)

}

Table FIN_DIC_TIPO_MOVIMENTO_STOCK {
  ID int
  TIPO_MOVIMENTO varchar(255)
  DESCRICAO varchar(255)

}

Table FIN_DIVIDAS_ATIVIDADE {
  ID int
  ID_CLIENTE varchar(255)
  DATA_CRIA datetime
  UTZ_CRIA int
  DESCRICAO varchar(255)

}

Table FIN_DOC_ACORDO {
  ID int
  ID_CLIENTE varchar(255)
  DOCUMENTO varchar(255)

}

Table FIN_REGISTO_ACOES {
  ID_ACAO int
  ID_CLIENTE varchar(255)
  DATA_CRIA datetime
  UTZ_CRIA int
  CONTACTO varchar(255)
  GERAR_ALERTA datetime
  ALERTA_GERADO bit
  ORIGEM varchar(255)
  DESCRICAO varchar(255)
  TAMANHO_FICHEIRO float
  NOME_FICHEIRO varchar(255)
  DATATYPE_FICHEIRO varchar(255)
  TYPE_FICHEIRO varchar(255)
  FICHEIRO varchar(255)
  FICHEIRO_2 varchar(255)

}











Table FIN_DADOS_DIVIDAS_DASHBOARD {
  Valor_Total_Acordos decimal(38, 6)
  Total_em_Divida decimal(38, 6)
  Media_atraso_divida decimal(16, 2)
  Divida_31dias decimal(9, 0)
  Data_Analise date
}
Table FIN_DADOS_DIVIDAS_LISTA_ANALISE {
  kam varchar(255)
  ID_ENTIDADE varchar(6)
  NOME_ENTIDADE varchar(255)
  valor_divida decimal(38, 6)
  total_divida_venc decimal(38, 6)
  nao_vencido decimal(38, 6)
  vencido_ate_30 decimal(38, 6)
  vencido_31_60 decimal(38, 6)
  vencido_61_90 decimal(38, 6)
  vencido_mais_91 decimal(38, 6)
  AcordoFin decimal(38, 6)
  MediaPag decimal(16, 0)
  MediaAtraso decimal(16, 2)
  Data_Analise date
}
Table FIN_DADOS_DIVIDAS_LISTA_DOCUMENTOS {
  ID_ENTIDADE varchar(6)
  NUM_DOC varchar(23)
  DATA_DOC date
  DATA_VENC date
  MORA int
  valor_divida decimal(36, 6)
  nao_vencido decimal(36, 6)
  vencido_ate_30 decimal(36, 6)
  vencido_31_60 decimal(36, 6)
  vencido_61_90 decimal(36, 6)
  vencido_mais_121 decimal(36, 6)
  AcordoFin decimal(36, 6)
  Data_Analise date
  ID_CAB_DOC int
}
Table FIN_DIC_AREAS_NEGOCIO {
  id_area_negocio int
  descricao varchar(50)
}
Table FIN_DIC_LINHAS_RELATORIO {
  id_linha int
  descricao varchar(100)
}
Table FIN_DIC_MOTIVOS_REGULARIZACAO {
  id_motivo_regularizacao int
  descricao varchar(50)
}
Table FIN_FATURACAO_TOTAL {
  MES int
  ANO int
  FATURACAO_TOTAL decimal(36, 2)
}
Table FIN_LISTA_DOCUMENTOS {
  NOME_FICHEIRO varchar(250)
  DATA_UPDATE datetime
  DATA_INSERT datetime
}
Table FIN_PAR_VENDAS {
  codref varchar(50)
  desref varchar(200)
  chave varchar(100)
  id_area_negocio int
  percentagem decimal(18, 2)
  estado bit
  id_linha_vendas int
  id_linha_devolucao int
  id_linha_desconto int
  id_linha_retificacao int
  data_ini date
}
Table FIN_SEGUIMENTO_FATURACAO {
  DATA date
  PRIMEIRO_DIA_MES bit
  DOMINGO bit
  ULTIMO_DIA_MES bit
  REALIZADO decimal(36, 2)
  ENCOMENDADO decimal(36, 2)
  ATRASO decimal(36, 2)
  VALOR_STOCK decimal(36, 2)
  PREVISAO_VENDAS_M1 varchar(10)
  DATA_PREVISAO_VENDAS_M1 date
  PREVISAO_VENDAS_M2 decimal(36, 2)
  DATA_PREVISAO_VENDAS_M2 date
}


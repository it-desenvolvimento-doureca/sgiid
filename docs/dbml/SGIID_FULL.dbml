// SGIID - Diagrama Completo
// 343 tabelas | 174 FKs (src+dst validadas)
// https://dbdiagram.io -> paste content here

// === AB ===
Table AB_DIC_BANHO {
  ID_BANHO int [pk, increment]
  ID_LINHA int
  ID_ZONA int
  NOME_BANHO varchar(255)
  ESTADO bit
  ID_TINA int
  OBS varchar(255)
  DATA_CRIA datetime
  UTZ_CRIA int
  DATA_ULT_MODIF datetime
  UTZ_ULT_MODIF int
  DATA_ANULACAO datetime
  UTZ_ANULACAO int
  INATIVO bit
  CELULAHULL bit
  EMAIL_PARA varchar(255)
  MANUTENCAOREPOSICAO bit
  MANUTENCAONAOPROGRAMADA bit
  DOSE1 varchar(255)
  DOSE2 varchar(255)
  DOSE3 varchar(255)
  DOSE4 varchar(255)
  DOSE5 varchar(255)
  DOSE6 varchar(255)

}

